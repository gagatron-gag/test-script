-- ── Freeze Logic ──────────────────────────────────────────────────────────────
local frozen = 0
local busy   = false

local function setDisabled(dis)
    for _, b in pairs(freezeBtns) do
        b.Active = not dis
        TW(b, 0.12, {BackgroundTransparency = dis and 0.55 or 0.1})
    end
    lockBtn.Active = not dis
    TW(lockBtn, 0.12, {BackgroundTransparency = dis and 0.55 or 0.1})
end

local function runFreeze(ftype)
    if busy then return end
    busy = true
    setDisabled(true)

    local target = inputBox.Text ~= "" and inputBox.Text or lp.Name
    if inputBox.Text ~= "" then addLog("Target: "..target, C.warn) end
    addLog("Starting "..ftype:upper().."...", C.cyan)

    progWrap.Visible = true
    local steps = fakeSteps[ftype]
    for i, step in ipairs(steps) do
        local pct = i / #steps
        TW(progFill, 0.22, {Size = UDim2.new(pct, 0, 1, 0)})
        progStatusLbl.Text = step[1]:sub(1, 38)
        progPctLbl.Text    = math.floor(pct * 100).."%"
        addLog(step[1], step[2])
        task.wait(0.28 + math.random() * 0.26)
    end
    task.wait(0.25)

    progWrap.Visible = false
    TW(progFill, 0.1, {Size = UDim2.new(0, 0, 1, 0)})

    if ftype == "freeze" then
        frozen += 1
    elseif ftype == "mass" then
        frozen += 247
    elseif ftype == "unfreeze" then
        frozen = 0
    end

    -- pulse metric labels
    TW(frozenLbl, 0.1, {TextTransparency = 0.6})
    TW(activeLbl,  0.1, {TextTransparency = 0.6})
    task.wait(0.12)
    frozenLbl.Text = tostring(frozen)
    activeLbl.Text = tostring(math.max(0, 247 - frozen))
    TW(frozenLbl, 0.2, {TextTransparency = 0})
    TW(activeLbl,  0.2, {TextTransparency = 0})

    setDisabled(false)
    busy = false
end

for id, btn in pairs(freezeBtns) do
    btn.MouseButton1Click:Connect(function()
