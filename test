-- ══════════════════════════════════════════
-- FREEZE SEQUENCE (cosmetic)
-- ══════════════════════════════════════════
local isFreezing = false
local STEPS = {
    {t = "Locating Trade Machine instance...",  d = 1.1},
    {t = "Establishing secure channel...",       d = 0.9},
    {t = "Injecting freeze packet [0x3AF]...",   d = 1.2},
    {t = "Suspending trade session thread...",   d = 1.0},
    {t = "Overriding trade lock state...",       d = 0.8},
    {t = "Synchronising server snapshot...",     d = 1.1},
    {t = "Writing state to memory buffer...",    d = 0.9},
    {t = "Sealing transaction layer...",         d = 1.0},
    {t = "Validating freeze integrity...",       d = 0.7},
    {t = "Protocol complete.",                   d = 0.5},
}

local function runFreeze()
    if isFreezing then return end
    isFreezing = true

    resultLbl.Text = ""
    btnTitle.Text  = "EXECUTING PROTOCOL..."
    btnSub.Text    = "Trade Machine freeze in progress"
    setStatus("ACTIVE  ·  freeze protocol running", COL_GREEN)

    for _, step in ipairs(STEPS) do
        stepLbl.Text = ">  " .. step.t
        task.wait(step.d)
    end

    resultLbl.Text = "[  OK  ]  Trade Machine frozen and locked."
    btnTitle.Text  = "TRADE MACHINE FROZEN"
    btnSub.Text    = "freeze protocol executed successfully"
    setStatus("DONE  ·  Trade Machine lock confirmed", COL_GREEN)
    TweenService:Create(btnAccent, TweenInfo.new(0.3), {BackgroundColor3 = COL_GREEN}):Play()

    task.wait(4)

    TweenService:Create(btnAccent, TweenInfo.new(0.3), {BackgroundColor3 = COL_ACCENT}):Play()
    stepLbl.Text   = ">  —"
    resultLbl.Text = ""
    btnTitle.Text  = "FREEZE TRADE MACHINE"
    btnSub.Text    = "click to execute freeze protocol"
    setStatus("IDLE  ·  awaiting command", COL_BLUE)
    isFreezing = false
end

freezeBtn.MouseButton1Click:Connect(function() task.spawn(runFreeze) end)
freezeBtn.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch then task.spawn(runFreeze) end
end)

