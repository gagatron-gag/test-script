-- ── Helpers ──────────────────────────────────────────────────────────────────
local function N(cls, props, parent)
    local o = Instance.new(cls)
    for k, v in pairs(props) do o[k] = v end
    if parent then o.Parent = parent end
    return o
end
local function CR(r, p)    N("UICorner",  {CornerRadius = UDim.new(0, r)}, p) end
local function ST(c, t, p) N("UIStroke",  {Color = c, Thickness = t or 1}, p) end
local function PAD(l,r,t,b,p) N("UIPadding",{PaddingLeft=UDim.new(0,l),PaddingRight=UDim.new(0,r),PaddingTop=UDim.new(0,t),PaddingBottom=UDim.new(0,b)},p) end
local function TW(obj, dur, props)
    TweenService:Create(obj, TweenInfo.new(dur, Enum.EasingStyle.Quad), props):Play()
end

