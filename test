end

-- ══════════════════════════════════════════
-- FREEZE SEQUENCE (cosmetic)
-- ══════════════════════════════════════════
local isFreezing = false
local STEPS = {
	{t = "Locating Trade Machine instance...",    p = 0.10, d = 1.1},
	{t = "Establishing secure channel...",         p = 0.20, d = 0.9},
	{t = "Injecting freeze packet [0x3AF]...",     p = 0.32, d = 1.2},
	{t = "Suspending trade session thread...",     p = 0.44, d = 1.0},
	{t = "Overriding trade lock state...",         p = 0.55, d = 0.8},
	{t = "Synchronising server snapshot...",       p = 0.66, d = 1.1},
	{t = "Writing state to memory buffer...",      p = 0.76, d = 0.9},
	{t = "Sealing transaction layer...",           p = 0.87, d = 1.0},
	{t = "Validating freeze integrity...",         p = 0.95, d = 0.7},
	{t = "Protocol complete.",                     p = 1.00, d = 0.5},
}

freezeBtn.MouseButton1Click:Connect(function()
	if isFreezing then return end
	isFreezing = true

	resultLbl.Text = ""
	btnTitle.Text  = "EXECUTING PROTOCOL..."
	btnSub.Text    = "Trade Machine freeze in progress"
	setStatus("ACTIVE  ·  freeze protocol running", COL_GREEN)

	for _, step in ipairs(STEPS) do
		stepLbl.Text = ">  " .. step.t
		barPct.Text  = math.floor(step.p * 100) .. "%"
		local tw = TweenService:Create(barFill,
			TweenInfo.new(0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{Size = UDim2.new(step.p, 0, 1, 0)}
		)
		tw:Play()
		tw.Completed:Wait()
		task.wait(step.d)
	end

	-- success
	resultLbl.Text = "[  OK  ]  Trade Machine frozen and locked."
	btnTitle.Text  = "TRADE MACHINE FROZEN"
	btnSub.Text    = "freeze protocol executed successfully"
	setStatus("DONE  ·  Trade Machine lock confirmed", COL_GREEN)
	TweenService:Create(btnAccent, TweenInfo.new(0.3), {BackgroundColor3 = COL_GREEN}):Play()
	TweenService:Create(barFill,   TweenInfo.new(0.3), {BackgroundColor3 = COL_GREEN}):Play()

	task.wait(4)

	-- reset
	TweenService:Create(barFill, TweenInfo.new(0.45), {
		Size             = UDim2.new(0, 0, 1, 0),
		BackgroundColor3 = COL_BLUE,
	}):Play()
	TweenService:Create(btnAccent, TweenInfo.new(0.3), {BackgroundColor3 = COL_ACCENT}):Play()
	task.wait(0.45)

	barPct.Text    = "0%"
	stepLbl.Text   = ">  —"
	resultLbl.Text = ""
	btnTitle.Text  = "FREEZE TRADE MACHINE"
	btnSub.Text    = "click to execute freeze protocol"
	setStatus("IDLE  ·  awaiting command", COL_BLUE)
	isFreezing = false
end)

