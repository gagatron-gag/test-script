-- ══════════════════════════════════════════
-- CUSTOM DRAG — PC + Mobile
-- ══════════════════════════════════════════
local dragging  = false
local dragStart = nil
local startPos  = nil

local function getDragInput(input)
    return input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch
end

local function updateDrag(input)
    if not dragging or not dragStart or not startPos then return end
    local delta = input.Position - dragStart
    local vp    = workspace.CurrentCamera.ViewportSize
    local newX  = math.clamp(startPos.X.Offset + delta.X, 0, vp.X - W)
    local newY  = math.clamp(startPos.Y.Offset + delta.Y, 0, vp.Y - H)
    main.Position = UDim2.new(0, newX, 0, newY)
end

topBar.InputBegan:Connect(function(input)
    if not getDragInput(input) then return end
    local mp = minBtn.AbsolutePosition
    local ms = minBtn.AbsoluteSize
    local ip = input.Position
    if ip.X >= mp.X and ip.X <= mp.X + ms.X
    and ip.Y >= mp.Y and ip.Y <= mp.Y + ms.Y then return end
    dragging  = true
    dragStart = input.Position
    startPos  = main.Position
    input.Changed:Connect(function()
        if input.UserInputState == Enum.UserInputState.End then
            dragging = false
        end
    end)
end)

UIS.InputChanged:Connect(function(input)
    if not dragging then return end
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        updateDrag(input)
    end
end)

