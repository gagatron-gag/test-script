-- ══════════════════════════════════════════
local function cleanUp(name)
    pcall(function()
        local cg = game:GetService("CoreGui")
        if cg:FindFirstChild(name) then cg:FindFirstChild(name):Destroy() end
    end)
    pcall(function()
        if gethui and gethui():FindFirstChild(name) then gethui():FindFirstChild(name):Destroy() end
    end)
    pcall(function()
        if playerGui and playerGui:FindFirstChild(name) then playerGui:FindFirstChild(name):Destroy() end
    end)
end
