local function Create3DButton(parent, text, pos, size, color, textColor)
	local Shadow = Instance.new("Frame", parent)
	Shadow.Size = size
	Shadow.Position = pos
	Shadow.BackgroundColor3 = color:Lerp(Color3.new(0, 0, 0), 0.45)
	Shadow.BorderSizePixel = 0
	Instance.new("UICorner", Shadow).CornerRadius = UDim.new(0, 8)

	local Top = Instance.new("TextButton", Shadow)
	Top.Size = UDim2.new(1, 0, 1, 0)
	Top.Position = UDim2.new(0, 0, 0, -3)
	Top.BackgroundColor3 = color
	Top.Text = text
	Top.Font = Enum.Font.GothamBold
	Top.TextSize = 14
	Top.TextColor3 = textColor or Color3.new(1, 1, 1)
	Top.AutoButtonColor = false
	Top.BorderSizePixel = 0
	Instance.new("UICorner", Top).CornerRadius = UDim.new(0, 8)

	Top.MouseButton1Down:Connect(function()
		TweenService:Create(Top, TweenInfo.new(0.08, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 0, 0, 0)}):Play()
	end)

	Top.MouseButton1Up:Connect(function()
		TweenService:Create(Top, TweenInfo.new(0.08, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 0, 0, -3)}):Play()
	end)

	return Top
end

